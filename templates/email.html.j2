<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Kyber digest — {{ date_cz }}</title>
  <!--[if mso]><noscript><xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml></noscript><![endif]-->
  <style>
    body, table, td, p, a, li, h2, h3 {
      -webkit-text-size-adjust: 100%;
      -ms-text-size-adjust: 100%;
    }
    table, td { mso-table-lspace: 0pt; mso-table-rspace: 0pt; }
    img { border: 0; height: auto; line-height: 100%; outline: none; text-decoration: none; }

    body {
      margin: 0 !important;
      padding: 0 !important;
      background-color: #f1f5f9;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
                   "Helvetica Neue", Arial, sans-serif;
      font-size: 14px;
      color: #374151;
      line-height: 1.6;
    }

    /* Sekce — nadpis */
    .digest-content h2.digest-h2 {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: #3b82f6;
      background: none;
      border-left: none;
      border-bottom: 2px solid #dbeafe;
      border-radius: 0;
      padding: 0 0 5px 0;
      margin: 16px 0 0;
    }
    .digest-content h2.digest-h2:first-child { margin-top: 0; }

    .digest-content h3.digest-h3 {
      font-size: 12px;
      font-weight: 600;
      color: #6b7280;
      margin: 10px 0 4px;
    }

    /* Položky seznamu */
    .digest-content ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .digest-content ul li {
      font-size: 13.5px;
      color: #374151;
      padding: 7px 0;
      border-bottom: 1px solid #f1f5f9;
      line-height: 1.6;
      word-wrap: break-word;
      overflow-wrap: break-word;
    }

    /* Odstavce */
    .digest-content p {
      font-size: 13.5px;
      color: #374151;
      margin: 6px 0 0;
      line-height: 1.6;
      word-wrap: break-word;
      overflow-wrap: break-word;
    }

    .digest-content a {
      color: #3b82f6; text-decoration: none;
      word-wrap: break-word; overflow-wrap: break-word; word-break: break-all;
    }
    .digest-content a:hover { text-decoration: underline; }
    .digest-content em { color: #6b7280; font-style: italic; }
    .digest-content strong {
      font-weight: 700; color: #111827;
      word-wrap: break-word; overflow-wrap: break-word;
    }

    @media only screen and (max-width: 480px) {
      .email-header-td { padding: 14px 18px 12px !important; }
      .email-body-td   { padding: 16px 18px !important; }
      .email-footer-td { padding: 10px 18px !important; }
    }
  </style>
</head>
<body>

  <!-- Jediná tabulka, width=100%, žádný centrující wrapper -->
  <!-- table-layout:fixed zajistí zalamování textu v Outlooku (MSO engine) -->
  <table width="100%" cellpadding="0" cellspacing="0" border="0"
         style="width:100%;table-layout:fixed;background:#ffffff;">

    <!-- Hlavička -->
    <tr>
      <td class="email-header-td"
          style="background:#0f172a;padding:18px 32px 16px;">
        <p style="margin:0 0 4px;font-size:10px;font-weight:600;
                  letter-spacing:.12em;text-transform:uppercase;color:#3b82f6;">
          &#128737;&#65039; Kybernetický digest
        </p>
        <p style="margin:0;font-size:22px;font-weight:700;
                  color:#ffffff;line-height:1.2;">
          {{ date_cz }}
        </p>
        {% if subject_line %}
        <p style="margin:6px 0 0;font-size:13px;color:#94a3b8;line-height:1.4;">
          {{ subject_line }}
        </p>
        {% endif %}
      </td>
    </tr>

    <!-- Obsah -->
    <tr>
      <td class="email-body-td" width="100%"
          style="width:100%;padding:24px 32px 20px;background:#ffffff;
                 word-wrap:break-word;overflow-wrap:break-word;word-break:break-word;">
        <div class="digest-content"
             style="width:100%;max-width:100%;word-wrap:break-word;overflow-wrap:break-word;">
          {{ summary | safe }}
        </div>
      </td>
    </tr>

    <!-- Patička -->
    <tr>
      <td class="email-footer-td"
          style="background:#f8fafc;border-top:1px solid #e2e8f0;
                 padding:12px 32px;text-align:center;
                 font-size:11px;color:#94a3b8;line-height:1.5;">
        {% if web_url %}
        <p style="margin:0 0 6px;">
          <a href="{{ web_url }}" target="_blank"
             style="color:#3b82f6;text-decoration:none;font-weight:600;font-size:12px;">
            &#128196; Archiv všech souhrnů online
          </a>
        </p>
        {% endif %}
        Automaticky generováno pomocí Gemini AI ze zdrojů NÚKIB, CERT.CZ,
        Krebs on Security, The Hacker News, BleepingComputer, ENISA a Schneier on Security.
      </td>
    </tr>

  </table>

</body>
</html>
