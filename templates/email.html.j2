<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Kyber digest — {{ date_cz }}</title>
  <!--[if mso]><noscript><xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml></noscript><![endif]-->
  <style>
    body, table, td, p, a, li, h2, h3 {
      -webkit-text-size-adjust: 100%;
      -ms-text-size-adjust: 100%;
    }
    table, td { mso-table-lspace: 0pt; mso-table-rspace: 0pt; }
    img { border: 0; height: auto; line-height: 100%; outline: none; text-decoration: none; }

    body {
      margin: 0 !important;
      padding: 0 !important;
      background-color: #f1f5f9;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
                   "Helvetica Neue", Arial, sans-serif;
      font-size: 14px;
      color: #374151;
      line-height: 1.6;
    }

    .email-body { padding: 20px 28px 16px; }

    /* Sekce — nadpis */
    .digest-content h2.digest-h2 {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: #3b82f6;
      background: none;
      border-left: none;
      border-bottom: 2px solid #dbeafe;
      border-radius: 0;
      padding: 0 0 5px 0;
      margin: 16px 0 0;
    }
    .digest-content h2.digest-h2:first-child { margin-top: 0; }

    .digest-content h3.digest-h3 {
      font-size: 12px;
      font-weight: 600;
      color: #6b7280;
      margin: 10px 0 4px;
    }

    /* Položky seznamu */
    .digest-content ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .digest-content ul li {
      font-size: 13.5px;
      color: #374151;
      padding: 7px 0;
      border-bottom: 1px solid #f1f5f9;
      border-left: none;
      background: none;
      border-radius: 0;
      line-height: 1.6;
      word-wrap: break-word;
      overflow-wrap: break-word;
    }

    /* Odstavce */
    .digest-content p {
      font-size: 13.5px;
      color: #374151;
      margin: 6px 0 0;
      line-height: 1.6;
      word-wrap: break-word;
      overflow-wrap: break-word;
    }

    .digest-content a { color: #3b82f6; text-decoration: none; }
    .digest-content a:hover { text-decoration: underline; }
    .digest-content em { color: #6b7280; font-style: italic; }
    .digest-content strong { font-weight: 700; color: #111827; }

    @media only screen and (max-width: 480px) {
      .email-body { padding: 16px 18px !important; }
      .email-header-td { padding: 14px 18px 12px !important; }
      .email-footer-td { padding: 10px 18px !important; }
    }
  </style>
</head>
<body>
  <table width="100%" cellpadding="0" cellspacing="0" border="0"
         style="background-color:#f1f5f9;">
    <tr>
      <td align="center" style="padding:16px 8px;">

        <!--[if mso]>
        <table width="600" cellpadding="0" cellspacing="0" border="0"><tr><td>
        <![endif]-->

        <table width="600" cellpadding="0" cellspacing="0" border="0"
               style="max-width:600px;width:100%;background:#ffffff;
                      border-radius:8px;overflow:hidden;
                      border:1px solid #e2e8f0;">

          <!-- Hlavička -->
          <tr>
            <td class="email-header-td"
                style="background:#0f172a;padding:18px 28px 16px;">
              <p style="margin:0 0 4px;font-size:10px;font-weight:600;
                        letter-spacing:.12em;text-transform:uppercase;color:#3b82f6;">
                &#128737;&#65039; Kybernetický digest
              </p>
              <p style="margin:0;font-size:20px;font-weight:700;
                        color:#ffffff;line-height:1.2;">
                {{ date_cz }}
              </p>
              {% if subject_line %}
              <p style="margin:4px 0 0;font-size:12px;color:#94a3b8;
                        line-height:1.4;">
                {{ subject_line }}
              </p>
              {% endif %}
            </td>
          </tr>

          <!-- Obsah -->
          <tr>
            <td class="email-body">
              <div class="digest-content">
                {{ summary | safe }}
              </div>
            </td>
          </tr>

          <!-- Patička -->
          <tr>
            <td class="email-footer-td"
                style="background:#f8fafc;border-top:1px solid #e2e8f0;
                       padding:10px 28px;text-align:center;
                       font-size:11px;color:#94a3b8;line-height:1.5;">
              Automaticky generováno pomocí Gemini AI ze zdrojů NÚKIB, CERT.CZ,
              Krebs on Security, The Hacker News, BleepingComputer, ENISA a Schneier on Security.
            </td>
          </tr>

        </table>

        <!--[if mso]>
        </td></tr></table>
        <![endif]-->

      </td>
    </tr>
  </table>
</body>
</html>
