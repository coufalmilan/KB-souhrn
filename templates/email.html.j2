<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Kyber digest — {{ date_cz }}</title>
  <!--[if mso]><noscript><xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml></noscript><![endif]-->
  <style>
    body, table, td, p, a, li { -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
    table, td { mso-table-lspace: 0pt; mso-table-rspace: 0pt; }
    img { border: 0; height: auto; line-height: 100%; outline: none; text-decoration: none; }

    body {
      margin: 0 !important;
      padding: 0 !important;
      background-color: #f0f2f8;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
                   "Helvetica Neue", Arial, sans-serif;
      font-size: 15px;
      color: #1a1d23;
      line-height: 1.6;
    }

    /* Header */
    .email-header {
      background-color: #2563eb;
      padding: 24px 40px;
      color: #ffffff;
    }
    .email-header h1 {
      font-size: 20px;
      font-weight: 700;
      margin: 0 0 4px;
    }
    .email-header .subtitle {
      font-size: 13px;
      opacity: .85;
      margin: 0;
    }

    /* Body */
    .email-body {
      padding: 28px 44px;
    }

    /* Digest obsah */
    .digest-content h2.digest-h2 {
      font-size: 15px;
      font-weight: 700;
      color: #1e40af;
      background-color: #eff6ff;
      padding: 8px 12px;
      border-left: 4px solid #2563eb;
      border-radius: 0 6px 6px 0;
      margin: 20px 0 10px;
    }
    .digest-content h3.digest-h3 {
      font-size: 13px;
      font-weight: 600;
      color: #6b7280;
      margin: 12px 0 6px;
    }
    .digest-content p {
      font-size: 14px;
      color: #374151;
      margin: 0 0 10px;
      word-wrap: break-word;
      overflow-wrap: break-word;
    }
    .digest-content ul {
      list-style: none;
      padding: 0;
      margin: 0 0 10px;
    }
    .digest-content ul li {
      font-size: 13.5px;
      color: #374151;
      padding: 10px 20px 10px 14px;
      margin-bottom: 6px;
      border-left: 3px solid #dde1ea;
      background-color: #f8f9fc;
      border-radius: 0 5px 5px 0;
      line-height: 1.55;
      word-wrap: break-word;
      overflow-wrap: break-word;
    }
    .digest-content a {
      color: #2563eb;
      text-decoration: none;
      word-break: break-all;
    }
    .digest-content em { color: #6b7280; font-style: italic; }
    .digest-content strong { font-weight: 700; color: #111827; }

    /* Footer */
    .email-footer {
      background-color: #f8f9fc;
      border-top: 1px solid #e5e7eb;
      padding: 16px 40px;
      text-align: center;
      font-size: 12px;
      color: #9ca3af;
    }
    .email-footer a {
      color: #2563eb;
      text-decoration: none;
    }

    @media only screen and (max-width: 480px) {
      .email-header, .email-body, .email-footer {
        padding-left: 20px !important;
        padding-right: 20px !important;
      }
    }
  </style>
</head>
<body>
  <!-- Outer wrapper table -->
  <table width="100%" cellpadding="0" cellspacing="0" border="0"
         style="background-color:#f0f2f8; padding:24px 12px;">
    <tr>
      <td align="center">

        <!--[if mso]>
        <table width="640" cellpadding="0" cellspacing="0" border="0">
        <tr><td>
        <![endif]-->

        <!-- Inner container table -->
        <table width="640" cellpadding="0" cellspacing="0" border="0"
               style="max-width:640px; width:100%; background-color:#ffffff;
                      border-radius:10px; overflow:hidden;
                      border:1px solid #dde0ea;">

          <!-- Hlavička -->
          <tr>
            <td class="email-header">
              <h1>&#128737;&#65039; Kybernetický digest</h1>
              <p class="subtitle">{{ date_cz }}</p>
            </td>
          </tr>

          <!-- Obsah -->
          <tr>
            <td class="email-body">
              <div class="digest-content">
                {{ summary | safe }}
              </div>
            </td>
          </tr>

          <!-- Patička -->
          <tr>
            <td class="email-footer">
              Automaticky generováno pomocí Gemini AI ze zdrojů NÚKIB, CERT.CZ, Krebs on Security,
              The Hacker News, BleepingComputer, ENISA a Schneier on Security.<br>
              Pokud nechcete dostávat tento email, odhlaste se u administrátora.
            </td>
          </tr>

        </table>

        <!--[if mso]>
        </td></tr>
        </table>
        <![endif]-->

      </td>
    </tr>
  </table>
</body>
</html>
