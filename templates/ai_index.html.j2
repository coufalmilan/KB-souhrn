<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI digest — {{ date_cz }}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #f5f4fa;
      --surface:   #ffffff;
      --border:    #e2e0ea;
      --text:      #1a1d23;
      --muted:     #6b7280;
      --accent:    #7c3aed;
      --accent-h:  #6d28d9;
      --radius:    10px;
      --shadow:    0 2px 8px rgba(0,0,0,.08);
      --font:      system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --bg:      #0f0e17;
        --surface: #1a1823;
        --border:  #2d2b39;
        --text:    #e8eaf0;
        --muted:   #9ca3af;
        --accent:  #a78bfa;
        --accent-h:#c4b5fd;
        --shadow:  0 2px 8px rgba(0,0,0,.4);
      }
    }

    body {
      font-family: var(--font);
      background: var(--bg);
      color: var(--text);
      line-height: 1.65;
      font-size: 16px;
    }

    .page-wrap {
      max-width: 860px;
      margin: 0 auto;
      padding: 0 1rem 3rem;
    }

    header {
      background: var(--accent);
      color: #fff;
      padding: 1.4rem 1rem;
      margin-bottom: 2rem;
    }
    header .inner {
      max-width: 860px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
    }
    header .icon {
      font-size: 2rem;
      line-height: 1;
    }
    header h1 {
      font-size: 1.5rem;
      font-weight: 700;
      letter-spacing: -.5px;
    }
    header .subtitle {
      font-size: .9rem;
      opacity: .85;
    }

    .date-badge {
      display: inline-flex;
      align-items: center;
      gap: .4rem;
      background: var(--accent);
      color: #fff;
      font-size: .8rem;
      font-weight: 600;
      padding: .25rem .75rem;
      border-radius: 99px;
      margin-bottom: 1.2rem;
      letter-spacing: .02em;
    }

    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 1.5rem 1.75rem;
      margin-bottom: 1.5rem;
    }
    .card-title {
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 1rem;
      color: var(--text);
      border-bottom: 2px solid var(--border);
      padding-bottom: .5rem;
    }

    .digest-content h2.digest-h2 {
      font-size: 1.05rem;
      font-weight: 700;
      margin: 1.4rem 0 .6rem;
      padding: .35rem .75rem;
      border-left: 4px solid var(--accent);
      background: color-mix(in srgb, var(--accent) 8%, transparent);
      border-radius: 0 var(--radius) var(--radius) 0;
      color: var(--text);
    }
    .digest-content h3.digest-h3 {
      font-size: .95rem;
      font-weight: 600;
      margin: 1rem 0 .4rem;
      color: var(--muted);
    }
    .digest-content p {
      margin-bottom: .75rem;
      font-size: .95rem;
    }
    .digest-content ul {
      list-style: none;
      padding: 0;
      margin-bottom: .75rem;
    }
    .digest-content ul li {
      font-size: .92rem;
      padding: .55rem .75rem .55rem 1rem;
      margin-bottom: .4rem;
      border-left: 3px solid var(--border);
      background: var(--bg);
      border-radius: 0 6px 6px 0;
      line-height: 1.5;
    }
    .digest-content ul li:hover {
      border-left-color: var(--accent);
    }
    .digest-content a {
      color: var(--accent);
      text-decoration: none;
      word-break: break-all;
    }
    .digest-content a:hover { text-decoration: underline; color: var(--accent-h); }
    .digest-content em { color: var(--muted); font-style: italic; }
    .digest-content strong { font-weight: 700; }

    .archive-list {
      list-style: none;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: .5rem;
    }
    .archive-list li a {
      display: block;
      padding: .5rem .75rem;
      border: 1px solid var(--border);
      border-radius: 6px;
      font-size: .88rem;
      color: var(--text);
      text-decoration: none;
      transition: border-color .15s, background .15s;
    }
    .archive-list li a:hover {
      border-color: var(--accent);
      background: color-mix(in srgb, var(--accent) 6%, transparent);
      color: var(--accent);
    }
    .archive-list li a .arc-date {
      font-size: .78rem;
      color: var(--muted);
      display: block;
    }

    footer {
      text-align: center;
      font-size: .8rem;
      color: var(--muted);
      margin-top: 2rem;
      padding-top: 1rem;
      border-top: 1px solid var(--border);
    }

    @media (max-width: 600px) {
      .card { padding: 1.1rem 1.1rem; }
      header h1 { font-size: 1.2rem; }
      .archive-list { grid-template-columns: 1fr 1fr; }
    }
  </style>
</head>
<body>

<header>
  <div class="inner">
    <div class="icon">🤖</div>
    <div>
      <h1>AI digest</h1>
      <div class="subtitle">Automatický přehled novinek ze světa umělé inteligence</div>
    </div>
  </div>
</header>

<div class="page-wrap">

  <div class="date-badge">📅 {{ date_cz }}</div>

  <div class="card">
    <div class="card-title">Dnešní přehled</div>
    <div class="digest-content">
      {{ summary | safe }}
    </div>
  </div>

  {% if archive and archive | length > 1 %}
  <div class="card">
    <div class="card-title">📂 Archív — posledních {{ [archive | length, 30] | min }} dní</div>
    <ul class="archive-list">
      {% for entry in archive %}
      <li>
        <a href="{{ entry.url }}">
          <span class="arc-date">{{ entry.date }}</span>
          {{ entry.title }}
        </a>
      </li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}

</div>

<footer>
  Generováno {{ generated }} &nbsp;·&nbsp; Zdroje: OpenAI Blog, Google DeepMind, Hugging Face, MIT Technology Review, VentureBeat AI, TechCrunch AI, Ars Technica AI, The Verge AI, Wired AI
</footer>

</body>
</html>
