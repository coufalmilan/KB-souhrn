<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI digest — {{ date_cz }}</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #f5f4fa;
      --surface:   #ffffff;
      --border:    #e2e0ea;
      --text:      #1a1d23;
      --muted:     #6b7280;
      --accent:    #7c3aed;
      --accent-h:  #6d28d9;
      --radius:    10px;
      --shadow:    0 2px 8px rgba(0,0,0,.08);
      --font:      system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --bg:      #0f0e17;
        --surface: #1a1823;
        --border:  #2d2b39;
        --text:    #e8eaf0;
        --muted:   #9ca3af;
        --accent:  #a78bfa;
        --accent-h:#c4b5fd;
        --shadow:  0 2px 8px rgba(0,0,0,.4);
      }
    }

    html {
      font-size: clamp(14px, 1.5vw + 9.3px, 16px);
    }

    body {
      font-family: var(--font);
      background: var(--bg);
      color: var(--text);
      line-height: 1.65;
      min-width: 0;
    }

    /* ── HEADER ───────────────────────────────────────── */
    header {
      background: var(--accent);
      color: #fff;
      padding: clamp(.9rem, 3vw, 1.4rem) clamp(.75rem, 5vw, 1.5rem);
      margin-bottom: clamp(1.25rem, 4vw, 2rem);
    }
    header .inner {
      max-width: 860px;
      margin: 0 auto;
      display: flex;
      align-items: flex-start;
      gap: clamp(.5rem, 2vw, 1rem);
      flex-wrap: wrap;
      min-width: 0;
    }
    header .header-text { min-width: 0; }
    header .back-link {
      display: inline-block;
      color: rgba(255,255,255,.85);
      font-size: clamp(.78rem, 2vw, .9rem);
      text-decoration: none;
      margin-bottom: .35rem;
    }
    header .back-link:hover { color: #fff; text-decoration: underline; }
    header h1 {
      font-size: clamp(1rem, 3.5vw, 1.3rem);
      font-weight: 700;
      line-height: 1.2;
      overflow-wrap: break-word;
      word-break: break-word;
    }

    /* ── OBSAH ────────────────────────────────────────── */
    .page-wrap {
      max-width: 860px;
      width: 100%;
      margin: 0 auto;
      padding: 0 clamp(.75rem, 5vw, 1.5rem) clamp(2rem, 5vw, 3rem);
    }

    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: clamp(.9rem, 3.5vw, 1.75rem) clamp(.9rem, 4vw, 1.75rem);
      margin-bottom: clamp(1rem, 3vw, 1.5rem);
      min-width: 0;
      overflow: hidden;
    }
    .card-title {
      font-size: clamp(.95rem, 2.5vw, 1.05rem);
      font-weight: 700;
      margin-bottom: clamp(.75rem, 2vw, 1rem);
      border-bottom: 2px solid var(--border);
      padding-bottom: .5rem;
    }

    /* ── OBSAH DIGESTU ────────────────────────────────── */
    .digest-content {
      min-width: 0;
      overflow-x: hidden;
    }
    .digest-content h2.digest-h2 {
      font-size: clamp(.95rem, 2.5vw, 1.05rem);
      font-weight: 700;
      margin: clamp(1rem, 3vw, 1.4rem) 0 .6rem;
      padding: .35rem clamp(.5rem, 2vw, .75rem);
      border-left: 4px solid var(--accent);
      background: color-mix(in srgb, var(--accent) 8%, transparent);
      border-radius: 0 var(--radius) var(--radius) 0;
    }
    .digest-content h3.digest-h3 {
      font-size: clamp(.88rem, 2vw, .95rem);
      font-weight: 600;
      margin: 1rem 0 .4rem;
      color: var(--muted);
    }
    .digest-content p {
      margin-bottom: .75rem;
      font-size: clamp(.88rem, 2vw, .95rem);
      overflow-wrap: break-word;
      word-break: break-word;
    }
    .digest-content ul {
      list-style: none;
      padding: 0;
      margin-bottom: .75rem;
    }
    .digest-content ul li {
      font-size: clamp(.85rem, 2vw, .92rem);
      padding: clamp(.4rem, 1.5vw, .55rem) clamp(.5rem, 2vw, .75rem)
               clamp(.4rem, 1.5vw, .55rem) clamp(.6rem, 2.5vw, 1rem);
      margin-bottom: .4rem;
      border-left: 3px solid var(--border);
      background: var(--bg);
      border-radius: 0 6px 6px 0;
      line-height: 1.55;
      min-width: 0;
      overflow-wrap: break-word;
      word-break: break-word;
    }
    .digest-content ul li:hover { border-left-color: var(--accent); }
    .digest-content a {
      color: var(--accent);
      text-decoration: none;
      overflow-wrap: break-word;
      word-break: break-word;
    }
    .digest-content a:hover { text-decoration: underline; color: var(--accent-h); }
    .digest-content em { color: var(--muted); }
    .digest-content strong { font-weight: 700; }

    /* ── TABULKY V DIGESTU ────────────────────────────── */
    .digest-content .table-wrap {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      margin-bottom: .75rem;
      border-radius: var(--radius);
      border: 1px solid var(--border);
    }
    .digest-content table {
      width: 100%;
      min-width: 400px;
      border-collapse: collapse;
      font-size: clamp(.82rem, 1.8vw, .9rem);
    }
    .digest-content th,
    .digest-content td {
      padding: clamp(.35rem, 1.5vw, .55rem) clamp(.5rem, 2vw, .75rem);
      border-bottom: 1px solid var(--border);
      border-right: 1px solid var(--border);
      text-align: left;
      vertical-align: top;
      overflow-wrap: break-word;
      word-break: break-word;
    }
    .digest-content th:last-child,
    .digest-content td:last-child { border-right: none; }
    .digest-content tr:last-child td { border-bottom: none; }
    .digest-content th {
      background: color-mix(in srgb, var(--accent) 10%, var(--surface));
      font-weight: 600;
      color: var(--text);
      white-space: nowrap;
    }
    .digest-content tr:nth-child(even) td {
      background: color-mix(in srgb, var(--bg) 60%, var(--surface));
    }

    /* ── FOOTER ───────────────────────────────────────── */
    footer {
      text-align: center;
      font-size: clamp(.72rem, 1.8vw, .8rem);
      color: var(--muted);
      margin-top: clamp(1.5rem, 4vw, 2rem);
      padding: 1rem clamp(.75rem, 5vw, 1.5rem) 2rem;
      border-top: 1px solid var(--border);
    }
    footer a { color: var(--accent); }

    /* ── BREAKPOINTY ──────────────────────────────────── */
    @media (max-width: 480px) {
      header .inner { align-items: flex-start; }
      .digest-content h2.digest-h2 { border-radius: 0 6px 6px 0; }
    }
  </style>
</head>
<body>

<header>
  <div class="inner">
    <div class="header-text">
      <a class="back-link" href="../index.html">← Zpět na dnešní AI digest</a>
      <h1>🤖 AI digest — {{ date_cz }}</h1>
    </div>
  </div>
</header>

<div class="page-wrap">
  <div class="card">
    <div class="card-title">Přehled za {{ date_cz }}</div>
    <div class="digest-content">
      {{ summary | safe }}
    </div>
  </div>
</div>

<footer>
  Generováno {{ generated }} &nbsp;·&nbsp;
  <a href="../index.html">Zpět na hlavní stránku</a>
</footer>

<script>
  /* Zabalí každou tabulku v digestu do scrollovatelného wrapperu */
  document.querySelectorAll('.digest-content table').forEach(function(t) {
    if (t.parentElement.classList.contains('table-wrap')) return;
    var w = document.createElement('div');
    w.className = 'table-wrap';
    t.parentNode.insertBefore(w, t);
    w.appendChild(t);
  });
</script>

</body>
</html>
